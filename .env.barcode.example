# ========================
# EAN-Search Barcode Configuration
# ========================

# EAN-Search API Token (get from https://www.ean-search.org/mcp)
# Default provided token: d2890af90c79c45cc9b0c9caab16337d7a66fc07
# Register your own at: https://www.ean-search.org/api/
EAN_SEARCH_TOKEN=d2890af90c79c45cc9b0c9caab16337d7a66fc07

# Barcode Cache TTL (in milliseconds, default: 24 hours = 86400000)
# BARCODE_CACHE_TTL=86400000

# Barcode API Max Retries (default: 2)
# BARCODE_MAX_RETRIES=2

# Barcode API Retry Delay (in milliseconds, default: 1000)
# BARCODE_RETRY_DELAY=1000
