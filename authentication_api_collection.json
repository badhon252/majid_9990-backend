{
      "info": {
            "name": "Authentication API",
            "description": "Postman collection for authentication APIs including signup, login, forgot password, and change password.",
            "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
      },
      "item": [
            {
                  "name": "Signup",
                  "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"yourpassword\"\n}"
                        },
                        "url": {
                              "raw": "{{base_url}}/signup",
                              "host": ["{{base_url}}"],
                              "path": ["signup"]
                        }
                  }
            },
            {
                  "name": "Login",
                  "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"yourpassword\"\n}"
                        },
                        "url": {
                              "raw": "{{base_url}}/login",
                              "host": ["{{base_url}}"],
                              "path": ["login"]
                        }
                  }
            },
            {
                  "name": "Forgot Password",
                  "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n    \"email\": \"user@example.com\"\n}"
                        },
                        "url": {
                              "raw": "{{base_url}}/forgot-password",
                              "host": ["{{base_url}}"],
                              "path": ["forgot-password"]
                        }
                  }
            },
            {
                  "name": "Change Password",
                  "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n    \"email\": \"user@example.com\",\n    \"oldPassword\": \"youroldpassword\",\n    \"newPassword\": \"yournewpassword\"\n}"
                        },
                        "url": {
                              "raw": "{{base_url}}/change-password",
                              "host": ["{{base_url}}"],
                              "path": ["change-password"]
                        }
                  }
            },
            {
                  "name": "Unified Device Analysis",
                  "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n    \"imei\": \"123456789012345\",\n    \"serviceId\": 6\n}"
                        },
                        "url": {
                              "raw": "{{base_url}}/imei/device-analysis",
                              "host": ["{{base_url}}"],
                              "path": ["imei", "device-analysis"]
                        }
                  }
            },
            {
                  "name": "Create Inventory From Barcode",
                  "request": {
                        "method": "POST",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "Bearer {{token}}"
                              }
                        ],
                        "body": {
                              "mode": "formdata",
                              "formdata": [
                                    {
                                          "key": "code",
                                          "value": "1234567890123",
                                          "type": "text"
                                    },
                                    {
                                          "key": "userId",
                                          "value": "6828f0b8c4c0f7c9d4a12345",
                                          "type": "text"
                                    },
                                    {
                                          "key": "imeiNumber",
                                          "value": "490154203237518",
                                          "type": "text"
                                    },
                                    {
                                          "key": "purchasePrice",
                                          "value": "250",
                                          "type": "text"
                                    },
                                    {
                                          "key": "currentState",
                                          "value": "new",
                                          "type": "text"
                                    },
                                    {
                                          "key": "image",
                                          "type": "file"
                                    }
                              ]
                        },
                        "url": {
                              "raw": "{{base_url}}/inventory/create-from-barcode",
                              "host": ["{{base_url}}"],
                              "path": ["inventory", "create-from-barcode"]
                        }
                  }
            }
      ]
}
