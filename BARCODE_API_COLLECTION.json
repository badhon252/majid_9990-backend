            "url": {
              "raw": "http://localhost:5000/api/v1/barcode/5901234123457",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "v1", "barcode", "5901234123457"]
            },
            "description": "Search for a product using an EAN/UPC/GTIN barcode code. Returns product details including name, brand, category, image, etc."
