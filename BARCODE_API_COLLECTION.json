    {
      "name": "Cache Management (Protected)",
      "item": [
        {
          "name": "Get Cache Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_AUTH_TOKEN",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/v1/barcode/stats/cache",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "v1", "barcode", "stats", "cache"]
            },
            "description": "Get cache statistics including size, TTL, and cache entries. Requires authentication."
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer YOUR_AUTH_TOKEN",
                    "type": "text"
                  }
                ],
                "url": {
                  "raw": "http://localhost:5000/api/v1/barcode/stats/cache",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "5000",
                  "path": ["api", "v1", "barcode", "stats", "cache"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"statusCode\": 200,\n  \"success\": true,\n  \"message\": \"Cache statistics retrieved\",\n  \"data\": {\n    \"size\": 5,\n    \"ttl\": 86400000,\n    \"entries\": [\n      {\n        \"key\": \"barcode_5901234123457\",\n        \"age\": 3600000\n      },\n      {\n        \"key\": \"name_coca-cola\",\n        \"age\": 7200000\n      }\n    ]\n  }\n}"
            }
          ]
        },
