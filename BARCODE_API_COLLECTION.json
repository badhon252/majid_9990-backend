              "body": "{\n  \"statusCode\": 200,\n  \"success\": true,\n  \"message\": \"Product found successfully\",\n  \"data\": {\n    \"name\": \"Coca-Cola 1.5L\",\n    \"brand\": \"The Coca-Cola Company\",\n    \"category\": \"Beverages\",\n    \"description\": \"Coca-Cola Classic 1.5 liters\",\n    \"barcode\": \"5901234123457\",\n    \"image\": \"https://example.com/image.jpg\",\n    \"rawData\": {\n      \"ean\": \"5901234123457\",\n      \"title\": \"Coca-Cola 1.5L\",\n      \"brand\": \"The Coca-Cola Company\",\n      \"category\": \"Beverages\"\n    }\n  }\n}"
            },
